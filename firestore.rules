rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - familyId: string (required)
    //   - email: string (required)
    //   - name: string (optional)
    //
    // Collection: families
    // Document ID: {familyId}
    // Fields:
    //   - members: list of strings (required, max 10)
    //   - babyProfile: map (optional)
    //   - activeFeeding: map (optional)
    //   - activeSleep: map (optional)
    //
    // Collection: families/{familyId}/events
    // Document ID: {eventId}
    // Fields:
    //   - type: string (required)
    //   - timestamp: number (required)
    //   - endTimestamp: number (optional)
    //   - details: map (optional)
    //   - notes: string (optional)
    //   - authorId: string (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isFamilyMember(familyId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/families/$(familyId)) &&
             request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
    }

    function isValidUser() {
      let data = request.resource.data;
      return data.keys().hasAll(['familyId', 'email']) &&
             data.familyId is string &&
             data.email is string &&
             (!('name' in data) || data.name is string);
    }

    function isValidFamily() {
      let data = request.resource.data;
      return data.keys().hasAll(['members']) &&
             data.members is list &&
             data.members.size() > 0 &&
             data.members.size() <= 10;
    }

    function isValidEvent() {
      let data = request.resource.data;
      return data.keys().hasAll(['type', 'timestamp', 'authorId']) &&
             data.type is string &&
             data.timestamp is number &&
             data.authorId == request.auth.uid &&
             (!('endTimestamp' in data) || data.endTimestamp is number) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() < 1000)) &&
             (!('details' in data) || data.details is map);
    }

    match /users/{userId} {
      allow read: if isUser(userId);
      allow create: if isUser(userId) && isValidUser();
      allow update: if isUser(userId) && isValidUser();
    }

    match /families/{familyId} {
      allow read: if isFamilyMember(familyId) || isUser(familyId);
      allow create: if isUser(familyId) && isValidFamily() && request.auth.uid in request.resource.data.members;
      allow update: if isFamilyMember(familyId) && isValidFamily();
    }

    match /families/{familyId}/events/{eventId} {
      allow read: if isFamilyMember(familyId);
      allow create: if isFamilyMember(familyId) && isValidEvent();
      allow update: if isFamilyMember(familyId) && isValidEvent();
      allow delete: if isFamilyMember(familyId);
    }
  }
}
